# UK49 Lunchtime Bot Environment Variables

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (get from https://console.groq.com - FREE tier)
GROQ_API_KEY=your_groq_api_key_here

# RapidAPI Key (get from https://rapidapi.com - FREE tier)
RAPIDAPI_KEY=your_rapidapi_key_here

# Database path (default is local SQLite)
DATABASE_URL=data/uk49_lunchtime.db

# LLM Model ID (Qwen3-32B via Groq - FREE)
LLM_MODEL=qwen/qwen3-32b

# Draw settings
DRAW_TYPE=LUNCHTIME
DRAW_TIME=12:49
DRAW_TIMEZONE=Europe/London

# Admin Telegram IDs (comma-separated, for admin commands)
ADMIN_IDS=

# Logging level
LOG_LEVEL=INFO
